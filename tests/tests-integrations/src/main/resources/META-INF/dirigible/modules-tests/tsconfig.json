{
  "compilerOptions": {
    "module": "ES2022",
    "target": "ES2022",
	"rootDir": "./src",
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "sourceMap": true,
    "lib": [
      "ES2022",
      "DOM"
    ],
    "declaration": true,
    "types": [
      "./types"
    ],
    "paths": {
      "@aerokit/sdk/*": [
        "./src/*",
        "./../../../../../../../../components/api/api-modules-javascript/src/main/resources/META-INF/dirigible/modules/src/*"
      ],
      "sdk/*": [
        "./src/*",
        "./../../../../../../../../components/api/api-modules-javascript/src/main/resources/META-INF/dirigible/modules/src/*"
      ]
    },
  	"strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "noImplicitThis": false,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*"
  ]
}
