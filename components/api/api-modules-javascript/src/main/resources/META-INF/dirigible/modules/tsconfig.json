{
  "compilerOptions": {
    "module": "ES2022",
	"target": "ES2022",
	"rootDir": "./src",
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "sourceMap": true,
    "lib": [
      "ES2022",
      "DOM"
    ],
    "declaration": true,
    "types": [
      "./types"
    ],
    "paths": {
      "@aerokit/sdk/*": [
        "./src/*"
      ],
      "sdk/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "src/**/*"
  ]
}
