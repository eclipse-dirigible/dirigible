package gen.events.${javaGenFolderName};

import org.flowable.engine.delegate.DelegateExecution;
import org.flowable.engine.delegate.JavaDelegate;

import gen.${javaGenFolderName}.data.${javaOwnerPerspective}.${ownerEntity}Entity;
import gen.${javaGenFolderName}.data.${javaOwnerPerspective}.${ownerEntity}Repository;
import gen.${javaGenFolderName}.data.${javaTargetPerspective}.${targetEntity}Entity;
import gen.${javaGenFolderName}.data.${javaTargetPerspective}.${targetEntity}Repository;

/**
 * Resolves ${targetEntity}.${targetField} into the process variable '${variable}' for the ${process}
 * process. Generated from the intent .glue file (a decision or user-task form referenced
 * ${targetEntity} by its relation) - do not edit; it is re-generated with the application. Runs as a
 * BPMN service task (flowable:delegateExpression="\${JavaTask}") right before the step that needs it,
 * so the value is read at the latest moment rather than baked in at process start.
 * <p>
 * Clear-D context: the process context holds only the trigger entity's id, so this loads the OWNER
 * (${ownerEntity}) by that id to read the foreign key, then loads the related ${targetEntity} and
 * publishes the wanted field. (Previously it read the FK straight from the start-time snapshot, which
 * no longer exists.)
 */
public class ${handler} implements JavaDelegate {

    private final ${ownerEntity}Repository ownerRepository = new ${ownerEntity}Repository();
    private final ${targetEntity}Repository repository = new ${targetEntity}Repository();

    @Override
    public void execute(DelegateExecution execution) {
        Object ownerKey = execution.getVariable("${ownerKeyProperty}");
        if (!(ownerKey instanceof Number)) {
            return;
        }
        ${ownerEntity}Entity owner = ownerRepository.findById(((Number) ownerKey).${ownerKeyAccessor}());
        if (owner == null || !(owner.${fkProperty} instanceof Number)) {
            return;
        }
        ${targetEntity}Entity entity = repository.findById(((Number) owner.${fkProperty}).${targetIdAccessor}());
        if (entity != null) {
            execution.setVariable("${variable}", entity.${targetField});
        }
    }
}
