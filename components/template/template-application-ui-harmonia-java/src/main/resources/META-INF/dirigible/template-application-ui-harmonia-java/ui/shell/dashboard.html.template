<!-- Generated by Eclipse Dirigible. Home dashboard: model-generated KPI tiles — report-attached
     KPI widgets and custom widgets — plus a preview tile per report (click -> open it embedded).
     Report tiles come from the reports store; custom widgets are baked into dashboardPage from the
     model. KPI-tile style adopted from the codbex dashboards. Reached via the Home icon ('/' and /dashboard). -->
<div x-data="dashboardPage" class="vbox size-full overflow-auto">
  <div class="vbox gap-6 p-5">
    <h3 x-h-text.h3 x-text="T('application-core:shell.nav.dashboard', 'Dashboard')"></h3>

    <!-- Key Indicators: report-attached KPI widgets (reports[].widget) plus custom kpi widgets
         (top-level widgets: - the number comes from the developer's REST endpoint). A count/value
         widget is a compact number tile; a list widget is a top-N mini table. Clicking a report
         tile opens the full report. -->
    <div class="vbox gap-3" x-show="kpis.length > 0 || customKpis.length > 0" x-cloak>
      <div class="hbox items-center gap-2 text-xs font-bold uppercase text-muted-foreground">
        <i role="img" x-h-lucide data-lucide="gauge" class="size-4"></i><span x-text="T('application-core:shell.dashboard.kpis', 'Key Indicators')"></span>
      </div>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <template x-for="w in customKpis" :key="w.name">
          <div x-h-card>
            <div x-h-card-header>
              <div class="hbox items-center gap-2 text-xs font-semibold uppercase text-muted-foreground">
                <i role="img" x-h-lucide :data-lucide="w.icon" class="size-4"></i><span x-text="T(w.tkey, w.label)"></span>
              </div>
            </div>
            <div x-h-card-content>
              <template x-if="w.value === null && !w.error"><div x-h-skeleton class="w-1/2 h-9"></div></template>
              <p x-show="w.value !== null && !w.error" class="text-3xl font-bold" x-text="customValueText(w)"></p>
              <p x-show="w.error" x-h-text.muted class="text-3xl font-bold">—</p>
              <p x-show="w.detail" x-h-text.muted class="text-xs" x-text="w.detail"></p>
            </div>
          </div>
        </template>
        <template x-for="r in kpis" :key="r.name">
          <div x-h-card role="button" tabindex="0" class="cursor-pointer"
               :class="r.widget.kind === 'list' ? 'sm:col-span-2' : ''"
               @click="openReport(r)" @keydown.enter.prevent="openReport(r)">
            <div x-h-card-header>
              <div class="hbox items-center gap-2 text-xs font-semibold uppercase text-muted-foreground">
                <i role="img" x-h-lucide :data-lucide="r.widget.icon" class="size-4"></i><span x-text="$store.reports.widgetLabel(r)"></span>
              </div>
            </div>
            <div x-h-card-content>
              <template x-if="r.widget.kind !== 'list'">
                <div>
                  <template x-if="!kpiState(r).loaded"><div x-h-skeleton class="w-1/2 h-9"></div></template>
                  <p x-show="kpiState(r).loaded && !kpiState(r).error" class="text-3xl font-bold" x-text="kpiValueText(r)"></p>
                  <p x-show="kpiState(r).error" x-h-text.muted class="text-3xl font-bold">—</p>
                  <p x-show="r.description" x-h-text.muted class="text-xs" x-text="r.description"></p>
                </div>
              </template>
              <template x-if="r.widget.kind === 'list'">
                <div class="overflow-x-auto">
                  <template x-if="!kpiState(r).loaded"><div x-h-skeleton class="w-full h-9"></div></template>
                  <p x-show="kpiState(r).error" x-h-text.muted class="text-3xl font-bold">—</p>
                  <table x-show="kpiState(r).loaded && !kpiState(r).error" class="w-full text-sm">
                    <thead>
                      <tr>
                        <template x-for="c in kpiColumns(r)" :key="c.alias">
                          <th class="py-1 pr-3 text-left font-semibold text-muted-foreground"
                              :class="kpiAlignClass(c)" x-text="c.label"></th>
                        </template>
                      </tr>
                    </thead>
                    <tbody>
                      <template x-for="(row, i) in kpiRows(r)" :key="i">
                        <tr>
                          <template x-for="c in kpiColumns(r)" :key="c.alias">
                            <td class="py-1 pr-3" :class="kpiAlignClass(c)" x-text="kpiCellText(r, row, c)"></td>
                          </template>
                        </tr>
                      </template>
                    </tbody>
                  </table>
                </div>
              </template>
            </div>
          </div>
        </template>
      </div>
    </div>

    <!-- Custom page widgets (top-level widgets: kind page): the developer's own HTML pages,
         embedded like report preview tiles. -->
    <div class="vbox gap-3" x-show="customPages.length > 0" x-cloak>
      <div class="grid grid-cols-1 gap-4 lg:grid-cols-2">
        <template x-for="w in customPages" :key="w.name">
          <div x-h-card>
            <div x-h-card-header>
              <h3 x-h-card-title class="hbox items-center gap-2">
                <i role="img" x-h-lucide :data-lucide="w.icon" class="size-4"></i><span x-text="T(w.tkey, w.label)"></span>
              </h3>
            </div>
            <div x-h-card-content class="vbox gap-2">
              <p x-show="w.detail" x-h-text.muted class="text-sm" x-text="w.detail"></p>
              <iframe :src="w.url" :title="w.label" loading="lazy"
                      style="width:100%; height:220px; border:0;"></iframe>
            </div>
          </div>
        </template>
      </div>
    </div>

    <!-- Reports -->
    <div class="vbox gap-3" x-show="reports.length > 0" x-cloak>
      <div class="hbox items-center gap-2 text-xs font-bold uppercase text-muted-foreground">
        <i role="img" x-h-lucide data-lucide="bar-chart-3" class="size-4"></i><span x-text="T('application-core:shell.nav.reports', 'Reports')"></span>
      </div>
      <div class="grid grid-cols-1 gap-4 lg:grid-cols-2">
        <template x-for="r in reports" :key="r.url">
          <div x-h-card>
            <div x-h-card-header>
              <h3 x-h-card-title class="hbox items-center gap-2 cursor-pointer" @click="openReport(r)">
                <i role="img" x-h-lucide data-lucide="bar-chart-3" class="size-4"></i><span x-text="$store.reports.displayLabel(r)"></span>
              </h3>
              <div x-h-card-action>
                <button x-h-button data-variant="transparent" data-size="icon-sm" @click="openReport(r)" aria-label="Open report">
                  <i role="img" x-h-lucide data-lucide="arrow-up-right"></i>
                </button>
              </div>
            </div>
            <!-- A simplified preview of the report (first rows, no toolbar/pagination); the full
                 report opens via the header / open button. The description (from the .report) tells
                 the user what the report is about. -->
            <div x-h-card-content class="vbox gap-2">
              <p x-show="r.description" x-h-text.muted class="text-sm" x-text="r.description"></p>
              <iframe :src="r.url + '?preview=1'" title="Report preview" loading="lazy"
                      style="width:100%; height:220px; border:0;"></iframe>
            </div>
          </div>
        </template>
      </div>
    </div>
  </div>
</div>
