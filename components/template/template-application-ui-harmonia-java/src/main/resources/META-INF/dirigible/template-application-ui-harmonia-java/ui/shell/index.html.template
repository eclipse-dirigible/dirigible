<!DOCTYPE html>
<!--
  Generated by Eclipse Dirigible based on model and template.
  Aggregate SPA entry for the Harmonia runtime. Generated once over the whole model;
  the entities are looped below (the no-collection generate exposes them as "models")
  for the sidebar nav, the route declarations, and the page-component script tags.

  Assets are embedded in the fat jar (Phase 1), NOT loaded from a CDN — for CSP/offline:
    - Alpine + Harmonia are webjars (org.webjars.npm:alpinejs / codbex__harmonia, pulled by
      components/resources/application-core), served version-less via webjars-locator at /webjars/.
    - Lucide is a webjar too (org.webjars.npm:lucide via application-core).
    - Pinecone Router has no published webjar, so it is vendored under application-core/vendor
      and served at /services/web/application-core/vendor/.
  Script load order is load-bearing: plugins -> app code (defer, document order) -> Alpine -> Harmonia -> Lucide.
-->
<html lang="en">

  <head>
    <meta charset="UTF-8" />
    <link rel="icon" sizes="any" href="data:;base64,iVBORw0KGgo=" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>${appTitle}</title>

    <link href="/webjars/codbex__harmonia/dist/harmonia.css" rel="stylesheet" />
    <link href="/services/web/application-core/shell/css/app.css" rel="stylesheet" />

    <!-- PapaParse — CSV parsing for the Documents File Preview pane (served version-less by webjars). -->
    <script src="/webjars/papaparse/papaparse.min.js"></script>

    <!-- Default Harmonia's colour scheme to light on first run (its own default is "auto" = follow
         the OS). Harmonia (loaded below) reads this key on every page and manages the `.dark` class
         itself, so the shell and the standalone form/report iframes stay in sync. The toolbar switch
         changes it via Harmonia.setColorScheme(). -->
    <script>
      (function () {
        try { if (!localStorage.getItem('codbex.harmonia.colorMode')) localStorage.setItem('codbex.harmonia.colorMode', 'light'); } catch (e) { /* no storage */ }
      })();
    </script>
  </head>

  <body class="vbox size-full" x-data="app">

    <div x-h-sheet-overlay="isOpen">
      <div x-h-sheet data-align="left" x-ref="overlay"></div>
    </div>

    <div x-h-split class="size-full" data-orientation="horizontal" data-variant="border">

      <!-- Sidebar panel -->
      <div x-h-split-panel :data-hidden="hiddenPanels.left" data-max="256" data-min="200"
           data-locked="true" data-gutterless="true" x-ref="sidebarPanel">
        <div x-h-sidebar x-ref="sidebar">
          <div x-h-sidebar-header>
            <div class="hbox items-center gap-2 p-1">
              <!-- Brand icon (template appIcon param / intent icon / default). A value containing '/' or
                   '.' is treated as an image URL (custom SVG/PNG, e.g. /services/web/<project>/logo.svg
                   or a data: URI); otherwise it is a Lucide icon name. -->
#if($appIcon.contains("/") || $appIcon.contains("."))
              <img src="${appIcon}" alt="${appTitle}" class="size-5" />
#else
              <i role="img" data-lucide="${appIcon}" class="size-5 text-primary"></i>
#end
              <span class="font-bold"#if($appDescription && $appDescription != '') title="${appDescription}"#end>${appTitle}</span>
            </div>
          </div>
          <div x-h-sidebar-content>
            <!-- Application: the built-in shell sections. -->
            <div x-h-sidebar-group>
              <div x-h-sidebar-group-label>Application</div>
              <div x-h-sidebar-group-content>
                <ul x-h-sidebar-menu>
                  <li x-h-sidebar-menu-item>
                    <button x-h-sidebar-menu-button :data-active="isDashboard" @click="navigate('/dashboard')">
                      <i role="img" data-lucide="layout-dashboard"></i><span>Dashboard</span>
                    </button>
                  </li>
                  <li x-h-sidebar-menu-item>
                    <button x-h-sidebar-menu-button :data-active="isActive('/inbox')" @click="navigate('/inbox')">
                      <i role="img" data-lucide="inbox"></i><span>Inbox</span>
                    </button>
                  </li>
                  <li x-h-sidebar-menu-item>
                    <button x-h-sidebar-menu-button :data-active="isActive('/documents')" @click="navigate('/documents')">
                      <i role="img" data-lucide="folder"></i><span>Documents</span>
                    </button>
                  </li>
                </ul>
              </div>
            </div>
#set($hasEntities = false)
#foreach($entity in $models)#if(($entity.layoutType == "LIST" || $entity.layoutType == "MANAGE" || $entity.layoutType == "LIST_MASTER" || $entity.layoutType == "MANAGE_MASTER" || $entity.layoutType == "MANAGE_DOCUMENT") && $entity.type == "PRIMARY")#set($hasEntities = true)#end#end
#if($hasEntities)
            <!-- Entities: the top-level model entities (list / manage / master). -->
            <div x-h-sidebar-group>
              <div x-h-sidebar-group-label>Entities</div>
              <div x-h-sidebar-group-content>
                <ul x-h-sidebar-menu>
#foreach($entity in $models)
#if(($entity.layoutType == "LIST" || $entity.layoutType == "MANAGE" || $entity.layoutType == "LIST_MASTER" || $entity.layoutType == "MANAGE_MASTER" || $entity.layoutType == "MANAGE_DOCUMENT") && $entity.type == "PRIMARY")
                  <li x-h-sidebar-menu-item>
                    <button x-h-sidebar-menu-button :data-active="isActive('/${entity.name}')" @click="navigate('/${entity.name}')">
                      <i role="img" data-lucide="#if($entity.iconName && $entity.iconName != '')${entity.iconName}#{else}list#end"></i>
                      <span x-text="navLabel('#if($entity.menuLabel && $entity.menuLabel != '')${entity.menuLabel}#{else}${entity.name}#end')"></span>
                    </button>
                  </li>
#end
#end
                </ul>
              </div>
            </div>
#end
            <!-- Reports: one entry per report, discovered at RUNTIME (the reports store walks the
                 project's registry tree) because intent reports are standalone pages in a different
                 gen folder than the shell, invisible at generation time. Selecting one shows it
                 embedded on /reports. -->
            <div x-h-sidebar-group x-show="$store.reports.items.length > 0" x-cloak>
              <div x-h-sidebar-group-label>Reports</div>
              <div x-h-sidebar-group-content>
                <ul x-h-sidebar-menu>
                  <template x-for="r in $store.reports.items" :key="r.url">
                    <li x-h-sidebar-menu-item>
                      <button x-h-sidebar-menu-button :data-active="isActive('/reports') && $store.reports.selected && $store.reports.selected.url === r.url" @click="$store.reports.selected = r; navigate('/reports')">
                        <i role="img" data-lucide="bar-chart-3"></i><span x-text="r.label"></span>
                      </button>
                    </li>
                  </template>
                </ul>
              </div>
            </div>
          </div>
#set($hasSettings = false)
#foreach($entity in $models)#if($entity.type == "SETTING")#set($hasSettings = true)#end#end
#if($hasSettings)
          <!-- Settings pinned to the sidebar footer (bottom-left), like codbex-athena-app. -->
          <div x-h-sidebar-footer>
            <ul x-h-sidebar-menu>
              <li x-h-sidebar-menu-item>
                <button x-h-sidebar-menu-button :data-active="isActive('/settings')" @click="navigate('/settings')">
                  <i role="img" data-lucide="settings"></i><span>Settings</span>
                </button>
              </li>
            </ul>
          </div>
#end
        </div>
      </div>

      <!-- Main panel -->
      <div x-h-split-panel>
        <div class="vbox size-full">
          <!-- Top bar (breadcrumb + notifications + theme + user) - hidden in embedded mode so an FK
               "Add" iframe dialog shows just the form, no shell chrome. -->
          <div x-h-toolbar data-variant="transparent" x-cloak x-show="!embedded">
            <button x-show="hiddenPanels.left && !embedded" x-h-button data-variant="transparent"
                    aria-label="Navigation" @click="openSideNav()" data-size="icon">
              <i role="img" data-lucide="menu"></i>
            </button>
            <nav x-h-breadcrumb data-overflow="scroll"
                 :data-variant="hiddenPanels.left ? 'outline' : 'default'" data-size="md">
              <ol x-h-breadcrumb-list>
                <li x-h-breadcrumb-item>
                  <span x-show="isDashboard" x-h-breadcrumb-page aria-label="Home">
                    <svg x-h-icon.home class="size-4" role="img" aria-label="Home"></svg>
                  </span>
                  <button x-show="!isDashboard" x-h-breadcrumb-link @click="navigate('/dashboard')" aria-label="Home">
                    <svg x-h-icon.home class="size-4" role="img" aria-label="Home"></svg>
                  </button>
                </li>
                <template x-for="(crumb, i) in breadcrumbTrail" :key="i">
                  <li x-h-breadcrumb-item>
                    <button x-show="crumb.route" x-h-breadcrumb-link @click="navigate(crumb.route)" x-text="crumb.label"></button>
                    <span x-show="!crumb.route" x-h-breadcrumb-page x-text="crumb.label"></span>
                  </li>
                </template>
              </ol>
            </nav>
            <div x-h-toolbar-spacer></div>

            <!-- Light/dark theme switch (a visible Lucide sun/moon). Backed by Harmonia's own
                 colour-scheme API, so every page — including the standalone form/report iframes that
                 load harmonia.min.js — honours the same choice. -->
            <button x-h-button data-variant="transparent" data-size="icon-sm" @click="$store.theme.toggle()"
                    :aria-label="$store.theme.value === 'dark' ? 'Switch to light theme' : 'Switch to dark theme'" title="Toggle theme">
              <i x-show="$store.theme.value !== 'dark'" role="img" data-lucide="moon"></i>
              <i x-show="$store.theme.value === 'dark'" role="img" data-lucide="sun"></i>
            </button>

            <!-- Notifications: the bell shows the unread count (absolutely positioned so the count
                 pill never widens the button into its neighbours); the popover lists them. -->
            <button x-h-button x-h-popover-trigger data-variant="transparent" data-size="icon-sm" aria-label="Notifications" class="relative">
              <i role="img" data-lucide="bell"></i>
              <!-- Small count badge tucked into the bell's bottom-right corner (doesn't cover the icon). -->
              <span x-show="$store.notifications.unreadCount > 0" class="absolute" x-text="$store.notifications.unreadCount"
                    style="right:-2px; bottom:-2px; min-width:15px; height:15px; padding:0 3px; border-radius:9999px; background:#e01b24; color:#fff; font-size:9px; line-height:15px; text-align:center; font-weight:700;"></span>
            </button>
            <div class="w-80" x-h-popover data-innerclicks="true">
              <div x-h-toolbar data-size="sm">
                <span x-h-toolbar-title class="shrink-0" x-text="'Notifications (' + $store.notifications.unreadCount + ')'"></span>
                <div x-h-toolbar-spacer></div>
                <button x-h-button data-variant="transparent" data-size="icon-sm" @click="$store.notifications.markAllRead()"
                        title="Mark all as read" aria-label="Mark all as read"><i role="img" data-lucide="check-check"></i></button>
              </div>
              <div x-show="$store.notifications.items.length === 0" x-h-text.muted class="p-3 text-sm">You're all caught up.</div>
              <ol x-show="$store.notifications.items.length" x-h-notification-list>
                <template x-for="n in $store.notifications.items" :key="n.id">
                  <li x-h-notification class="hbox" :data-unread="n.unread ? 'true' : 'false'"
                      :class="n.task ? 'cursor-pointer' : ''" @click="openNotification(n)">
                    <div x-h-notification-media><svg x-h-icon.circle-info class="size-5" role="img" aria-label="info"></svg></div>
                    <div class="vbox flex-1">
                      <h1 x-h-notification-title x-text="n.title"></h1>
                      <p x-h-notification-description x-text="n.description"></p>
                    </div>
                  </li>
                </template>
              </ol>
            </div>

            <!-- Logged-in user: a Lucide avatar; the dropdown shows the user name and Log out. -->
            <button x-h-button x-h-menu-trigger.dropdown data-variant="transparent" data-size="icon-sm"
                    :aria-label="$store.currentUser.name || 'Account'">
              <i role="img" data-lucide="circle-user"></i>
            </button>
            <ul x-h-menu aria-label="User menu" data-align="bottom-end">
              <div x-h-tile class="mb-1">
                <div x-h-tile-media><i role="img" data-lucide="circle-user" class="size-6"></i></div>
                <div x-h-tile-content>
                  <div x-h-tile-title x-text="$store.currentUser.name || 'User'"></div>
                </div>
              </div>
              <div x-h-menu-separator></div>
              <li x-h-menu-item data-variant="negative" @click="$store.currentUser.logout()">
                <i role="img" data-lucide="log-out"></i> Log out
              </li>
            </ul>
          </div>

          <div id="app" class="size-full overflow-auto flex-1">
            <!-- Pinecone Router renders the matched view fragment here. -->
          </div>
        </div>
      </div>

    </div>

    <!-- App-wide BPM task form dialog (driven by the processTasks store). The generated task form
         completes the task and the store re-fetches on close so badges drop the finished task. -->
    <div x-h-dialog-overlay :data-open="$store.processTasks.formOpen">
      <div x-h-dialog style="width: 92vw; max-width: 1100px;">
        <div x-h-dialog-header>
          <h2 x-h-dialog-title x-text="$store.processTasks.formTitle"></h2>
          <button x-h-dialog-close @click="$store.processTasks.closeForm()" aria-label="Close"></button>
        </div>
        <div x-h-dialog-content>
          <iframe x-show="$store.processTasks.formOpen" :src="$store.processTasks.formUrl"
                  title="Task form" style="width:100%; height:70vh; border:0;"></iframe>
        </div>
      </div>
    </div>

    <!-- App-wide transient toasts. Any component/form/glue raises one through Harmonia's
         notifications magic with the 'toast' template below (data: message + variant). -->
    <section x-h-notification-overlay>
      <template id="toast">
        <li x-h-notification.floating data-variant="toast" class="hbox items-center gap-3 min-w-3xs max-w-md">
          <div x-h-notification-media>
            <span x-h-avatar class="rounded-full" :data-variant="variant">
              <template x-if="variant === 'positive'"><svg x-h-icon.circle-success role="img" aria-label="success"></svg></template>
              <template x-if="variant === 'negative'"><svg x-h-icon.circle-error role="img" aria-label="error"></svg></template>
              <template x-if="variant !== 'positive' && variant !== 'negative'"><svg x-h-icon.circle-info role="img" aria-label="info"></svg></template>
            </span>
          </div>
          <span x-h-notification-title class="flex-1" x-text="message"></span>
          <div x-h-notification-actions data-orientation="vertical">
            <button x-h-button x-h-notification-close class="rounded-full" data-variant="transparent" data-size="icon-md" aria-label="Dismiss">
              <svg x-h-icon.close role="img" aria-label="close"></svg>
            </button>
          </div>
        </li>
      </template>
    </section>

    <!-- Routes (Pinecone reads these from the document). -->
    <!-- Home dashboard: model-generated KPI tiles (reached via the Home icon). -->
    <template x-route="/" x-template.target.app="./views/_dashboard.html"></template>
    <template x-route="/dashboard" x-template.target.app="./views/_dashboard.html"></template>
    <!-- Built-in shell sections (always present): Process Inbox + Documents. -->
    <template x-route="/inbox" x-template.target.app="/services/web/application-core/shell/views/_inbox.html"></template>
    <template x-route="/documents" x-template.target.app="/services/web/application-core/shell/views/_documents.html"></template>
#if($hasSettings)
    <!-- Settings landing: lists the setting entities (each still has its own CRUD route below). -->
    <template x-route="/settings" x-template.target.app="./views/_settings.html"></template>
#end
    <!-- Reports landing: always routed; the page lists reports discovered at runtime (reports store). -->
    <template x-route="/reports" x-template.target.app="/services/web/application-core/shell/views/_reports.html"></template>
    <!-- LIST entities: one read-only list route each. -->
#foreach($entity in $models)
#if($entity.layoutType == "LIST" && $entity.type == "PRIMARY")
    <template x-route="/${entity.name}" x-template.target.app="./views/${entity.perspectiveName}/${entity.name}-list.html"></template>
#end
#end
    <!-- MANAGE entities: CRUD list + shared create/edit form (same view for create + :id/edit). -->
#foreach($entity in $models)
#if($entity.layoutType == "MANAGE" && $entity.type == "PRIMARY")
    <template x-route="/${entity.name}" x-template.target.app="./views/${entity.perspectiveName}/${entity.name}-manage-list.html"></template>
    <template x-route="/${entity.name}/create" x-template.target.app="./views/${entity.perspectiveName}/${entity.name}-form.html"></template>
    <template x-route="/${entity.name}/:id/edit" x-template.target.app="./views/${entity.perspectiveName}/${entity.name}-form.html"></template>
    <template x-route="/${entity.name}/:id" x-template.target.app="./views/${entity.perspectiveName}/${entity.name}-manage-list.html"></template>
#end
#end
    <!-- SETTING entities: same CRUD list + form, grouped under the Settings perspective. -->
#foreach($entity in $models)
#if($entity.type == "SETTING")
    <template x-route="/${entity.name}" x-template.target.app="./views/${entity.perspectiveName}/${entity.name}-manage-list.html"></template>
    <template x-route="/${entity.name}/create" x-template.target.app="./views/${entity.perspectiveName}/${entity.name}-form.html"></template>
    <template x-route="/${entity.name}/:id/edit" x-template.target.app="./views/${entity.perspectiveName}/${entity.name}-form.html"></template>
    <template x-route="/${entity.name}/:id" x-template.target.app="./views/${entity.perspectiveName}/${entity.name}-manage-list.html"></template>
#end
#end
    <!-- MASTER entities: master-detail page (list + selected record's detail panels) + own form. -->
#foreach($entity in $models)
#if(($entity.layoutType == "MANAGE_MASTER" || $entity.layoutType == "LIST_MASTER") && $entity.type == "PRIMARY")
    <template x-route="/${entity.name}" x-template.target.app="./views/${entity.perspectiveName}/${entity.name}-master.html"></template>
    <template x-route="/${entity.name}/create" x-template.target.app="./views/${entity.perspectiveName}/${entity.name}-form.html"></template>
    <template x-route="/${entity.name}/:id/edit" x-template.target.app="./views/${entity.perspectiveName}/${entity.name}-form.html"></template>
#end
#end
    <!-- DOCUMENT entities (header-items): browse list + a full-page document editor at create/edit. -->
#foreach($entity in $models)
#if($entity.layoutType == "MANAGE_DOCUMENT" && $entity.type == "PRIMARY")
    <template x-route="/${entity.name}" x-template.target.app="./views/${entity.perspectiveName}/${entity.name}-manage-list.html"></template>
    <template x-route="/${entity.name}/create" x-template.target.app="./views/${entity.perspectiveName}/${entity.name}-document.html"></template>
    <template x-route="/${entity.name}/:id/edit" x-template.target.app="./views/${entity.perspectiveName}/${entity.name}-document.html"></template>
    <template x-route="/${entity.name}/:id" x-template.target.app="./views/${entity.perspectiveName}/${entity.name}-manage-list.html"></template>
#end
#end
    <!-- DETAIL entities: only a routed create/edit form (listed inside their master's panels). -->
#foreach($entity in $models)
#if(($entity.layoutType == "MANAGE_DETAILS" || $entity.layoutType == "LIST_DETAILS") && $entity.type == "DEPENDENT")
    <template x-route="/${entity.name}/create" x-template.target.app="./views/${entity.perspectiveName}/${entity.name}-form.html"></template>
    <template x-route="/${entity.name}/:id/edit" x-template.target.app="./views/${entity.perspectiveName}/${entity.name}-form.html"></template>
#end
#end
    <!-- REPORT entities: a table or chart page. -->
#foreach($entity in $models)
#if($entity.type == "REPORT")
    <template x-route="/${entity.name}" x-template.target.app="./views/${entity.perspectiveName}/${entity.name}-report.html"></template>
#end
#end
    <template x-route="notfound" x-template.target.app="/services/web/application-core/shell/views/_notfound.html"></template>

    <!-- Route segment -> nav label, from the model — read by appShell for the breadcrumb so the
         entity crumb reads the same as the sidebar (e.g. "Book" -> "Books"). -->
    <script>
      window.__harmoniaNav = {
#foreach($entity in $models)
        "${entity.name}": "#if($entity.menuLabel && $entity.menuLabel != '')${entity.menuLabel}#{else}${entity.name}#end",
#end
      };
    </script>

    <!-- 1. Plugins (vendored, no CDN) -->
    <script src="/services/web/application-core/vendor/pinecone-router.min.js"></script>

    <!-- 2. App code (defer keeps document order). The model-independent shell runtime is loaded ONCE
         from the shared location (/services/web/application-core/shell) - the same runtime the Harmonia
         application shell uses - so it is not copied per project. Only config.js, dashboardPage.js and
         the per-entity pages below are generated locally. -->
    <script src="/services/web/application-core/shell/js/app.js" defer></script>
    <script src="./js/config.js" defer></script>
    <script src="/services/web/application-core/shell/js/services/api.js" defer></script>
    <script src="/services/web/application-core/shell/js/services/apiError.js" defer></script>
    <script src="/services/web/application-core/shell/js/services/formValidation.js" defer></script>
    <script src="/services/web/application-core/shell/js/components/layout/appShell.js" defer></script>
    <script src="/services/web/application-core/shell/js/components/pages/basePage.js" defer></script>
    <script src="/services/web/application-core/shell/js/components/pages/baseFormPage.js" defer></script>
    <script src="/services/web/application-core/shell/js/components/detailPanel.js" defer></script>
    <script src="/services/web/application-core/shell/js/stores/processTasks.js" defer></script>
    <script src="/services/web/application-core/shell/js/stores/reports.js" defer></script>
    <script src="/services/web/application-core/shell/js/stores/currentUser.js" defer></script>
    <script src="/services/web/application-core/shell/js/stores/notifications.js" defer></script>
    <script src="/services/web/application-core/shell/js/stores/theme.js" defer></script>
    <script src="/services/web/application-core/shell/js/stores/related.js" defer></script>
    <script src="./js/components/pages/dashboardPage.js" defer></script>
    <script src="/services/web/application-core/shell/js/components/pages/inboxPage.js" defer></script>
    <script src="/services/web/application-core/shell/js/components/pages/documentsPage.js" defer></script>
    <script src="/services/web/application-core/shell/js/components/pages/settingsPage.js" defer></script>
#foreach($entity in $models)
#if($entity.layoutType == "LIST" && $entity.type == "PRIMARY")
    <script src="./js/components/pages/${entity.perspectiveName}/${entity.name}ListPage.js" defer></script>
#end
#if(($entity.layoutType == "MANAGE" && $entity.type == "PRIMARY") || $entity.type == "SETTING")
    <script src="./js/components/pages/${entity.perspectiveName}/${entity.name}ManageListPage.js" defer></script>
    <script src="./js/components/pages/${entity.perspectiveName}/${entity.name}FormPage.js" defer></script>
#end
#if(($entity.layoutType == "MANAGE_MASTER" || $entity.layoutType == "LIST_MASTER") && $entity.type == "PRIMARY")
    <script src="./js/components/pages/${entity.perspectiveName}/${entity.name}MasterPage.js" defer></script>
    <script src="./js/components/pages/${entity.perspectiveName}/${entity.name}FormPage.js" defer></script>
#end
#if($entity.layoutType == "MANAGE_DOCUMENT" && $entity.type == "PRIMARY")
    <script src="./js/components/pages/${entity.perspectiveName}/${entity.name}ManageListPage.js" defer></script>
    <script src="./js/components/pages/${entity.perspectiveName}/${entity.name}DocumentPage.js" defer></script>
#end
#if(($entity.layoutType == "MANAGE_DETAILS" || $entity.layoutType == "LIST_DETAILS") && $entity.type == "DEPENDENT")
    <script src="./js/components/pages/${entity.perspectiveName}/${entity.name}.detail.js" defer></script>
    <script src="./js/components/pages/${entity.perspectiveName}/${entity.name}FormPage.js" defer></script>
#end
#if($entity.type == "REPORT")
    <script src="./js/components/pages/${entity.perspectiveName}/${entity.name}ReportPage.js" defer></script>
#end
#end

    <!-- 3. Alpine LAST (Harmonia bundle auto-starts Alpine — do NOT call Alpine.start()) -->
    <script defer src="/webjars/alpinejs/dist/cdn.min.js"></script>
    <script src="/webjars/codbex__harmonia/dist/harmonia.min.js"></script>

    <!-- 4. Lucide icons (webjar) -->
    <script src="/webjars/lucide/dist/umd/lucide.min.js"></script>
    <!-- 5. Chart.js (webjar) — used by REPORT_BAR/LINE/PIE/... chart pages -->
    <script src="/webjars/chart.js/dist/chart.umd.js"></script>
    <script>
      document.addEventListener('alpine:initialized', () => {
        if (window.lucide) window.lucide.createIcons();
      }, { once: true });
      document.addEventListener('pinecone:end', () => {
        if (window.lucide) window.lucide.createIcons();
      });
    </script>

    <!-- Add-related dialog: an FK combobox's "Add" button (see the entity forms) opens the target
         entity's OWN generated create page in this iframe (App.utils.relatedCreateUrl, cross-model
         aware). The embedded form posts a 'harmonia.entity.created' message on save; the related store
         routes it to the opener, which refreshes that field's options and selects the new record.
         Bare/assignment $store access only (Velocity passes it through; no method-call escaping). -->
    <div x-h-dialog-overlay :data-open="$store.related.open">
      <div x-h-dialog data-size="lg">
        <div x-h-dialog-header>
          <h2 x-h-dialog-title x-text="$store.related.title"></h2>
          <button x-h-dialog-close @click="$store.related.open = false" aria-label="Close"></button>
        </div>
        <div x-h-dialog-content class="p-0">
          <iframe x-show="$store.related.open" :src="$store.related.src" title="Add new" style="width:100%; height:70vh; border:0;"></iframe>
        </div>
      </div>
    </div>
  </body>

</html>
