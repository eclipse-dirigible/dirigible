<!DOCTYPE html>
<!--
  Generated by Eclipse Dirigible based on model and template.
  Standalone Alpine.js + Harmonia report page for ${name}, rendered from a .report artifact. Opened
  directly (its own URL under gen/<genFolder>/reports/<name>/); queries the generated Java report
  controller via the self-contained client in report.js. Light by default (shares the shell's theme
  key in localStorage); dark when a `dark` class is on the root.
-->
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>${name}</title>
    <link href="/webjars/codbex__harmonia/dist/harmonia.css" rel="stylesheet" />
    <style>
      /* Theme `html` too (Harmonia only styles `body`) so the full page surface follows the theme.
         harmonia.min.js (below) applies the shared `codbex.harmonia.colorMode` the shell set, so this
         standalone report matches the shell's light/dark choice. */
      html, body { height: 100%; background-color: var(--background); color: var(--foreground); }
      [x-cloak] { display: none !important; }
    </style>
  </head>
  <body class="vbox size-full" x-data="reportPage" x-cloak>
    <div class="vbox size-full">
      <div x-h-toolbar data-variant="transparent">
        <span x-h-toolbar-title class="shrink-0" x-text="displayName"></span>
        <span x-show="state === 'default'" x-h-badge data-variant="information" x-text="count + ' rows'"></span>
        <div x-h-toolbar-spacer></div>
        <button x-h-button data-variant="outline" data-size="sm" @click="load()"><i role="img" data-lucide="refresh-cw"></i><span>Refresh</span></button>
        <button x-h-button data-variant="outline" data-size="sm" @click="exportCsv()"><i role="img" data-lucide="download"></i><span>Export</span></button>
      </div>

      <div x-show="state === 'loading'" class="p-4"><div x-h-spinner></div></div>
      <div x-show="state === 'error'" x-h-alert data-variant="negative" role="alert" class="m-4"><div x-h-alert-description x-text="error"></div></div>
      <div x-show="state === 'empty'" x-h-info-page class="p-4">
        <div x-h-info-page-header>
          <div x-h-info-page-media.icon><svg x-h-icon.circle-info role="img" aria-label="info"></svg></div>
          <div x-h-info-page-title>No data</div>
          <div x-h-info-page-description>The ${name} report returned no rows.</div>
        </div>
      </div>

      <div x-show="state === 'default'" class="vbox gap-2 p-4 flex-1 overflow-auto">
        <div x-h-table-container.scroll data-border="true">
          <table x-h-table data-borders="both">
            <thead x-h-table-header>
              <tr x-h-table-row>
                <template x-for="(col, i) in columns" :key="i"><th x-h-table-head scope="col" x-text="col"></th></template>
              </tr>
            </thead>
            <tbody x-h-table-body>
              <template x-for="(row, ri) in rows" :key="ri">
                <tr x-h-table-row data-hoverable="true">
                  <template x-for="(col, ci) in columns" :key="ci"><td x-h-table-cell x-text="row[col]"></td></template>
                </tr>
              </template>
            </tbody>
          </table>
        </div>

        <div class="hbox items-center gap-2">
          <button x-h-button data-variant="outline" data-size="sm" :disabled="page <= 1" @click="prev()"><i role="img" data-lucide="chevron-left"></i><span>Prev</span></button>
          <span x-h-text.muted x-text="'Page ' + page + ' / ' + totalPages"></span>
          <button x-h-button data-variant="outline" data-size="sm" :disabled="page >= totalPages" @click="next()"><span>Next</span><i role="img" data-lucide="chevron-right"></i></button>
        </div>
      </div>
    </div>

    <script src="./report.js"></script>
    <script defer src="/webjars/alpinejs/dist/cdn.min.js"></script>
    <script src="/webjars/codbex__harmonia/dist/harmonia.min.js"></script>
    <script src="/webjars/lucide/dist/umd/lucide.min.js"></script>
    <script>
      document.addEventListener('alpine:initialized', () => { if (window.lucide) window.lucide.createIcons(); }, { once: true });
    </script>
  </body>
</html>
