<!DOCTYPE html>
<!--
  Generated by Eclipse Dirigible based on model and template.
  Standalone Alpine.js + Harmonia report page for ${name}, rendered from a .report artifact. Opened
  directly (its own URL under gen/<genFolder>/reports/<name>/); queries the generated Java report
  controller via the self-contained client in report.js. Light by default (shares the shell's theme
  key in localStorage); dark when a `dark` class is on the root.
-->
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>${name}</title>
    <link href="/webjars/codbex__harmonia/dist/harmonia.css" rel="stylesheet" />
    <style>
      /* Theme `html` too (Harmonia only styles `body`) so the full page surface follows the theme.
         harmonia.min.js (below) applies the shared `codbex.harmonia.colorMode` the shell set, so this
         standalone report matches the shell's light/dark choice. */
      html, body { height: 100%; background-color: var(--background); color: var(--foreground); }
      [x-cloak] { display: none !important; }
    </style>
  </head>
  <body class="vbox size-full" x-data="reportPage" x-cloak>
    <div class="vbox size-full">
      <!-- Hidden in preview mode (the dashboard tile): no title/badge/toolbar, just the data. -->
      <div x-show="!preview" x-h-toolbar data-variant="transparent">
        <span x-h-toolbar-title class="shrink-0" x-text="displayName"></span>
        <span x-show="state === 'default'" x-h-badge data-variant="information" x-text="count + ' rows'"></span>
        <div x-h-toolbar-spacer></div>
#if($chart)
        <button x-h-button data-variant="outline" data-size="sm" @click="toggleView()">
          <i role="img" :data-lucide="view === 'chart' ? 'table-2' : 'bar-chart-3'"></i>
          <span x-text="view === 'chart' ? 'Table' : 'Chart'"></span>
        </button>
#end
        <button x-h-button data-variant="outline" data-size="sm" @click="showFilters = !showFilters; refreshIcons()">
          <i role="img" data-lucide="filter"></i><span>Filters</span>
          <span x-show="activeFilterCount > 0" x-h-badge data-variant="information" x-text="activeFilterCount"></span>
        </button>
        <button x-h-button data-variant="outline" data-size="sm" @click="load()"><i role="img" data-lucide="refresh-cw"></i><span>Refresh</span></button>
        <button x-h-button data-variant="outline" data-size="sm" @click="exportCsv()"><i role="img" data-lucide="download"></i><span>Export</span></button>
        <button x-h-button data-variant="outline" data-size="sm" @click="printReport()"><i role="img" data-lucide="printer"></i><span>Print</span></button>
      </div>

      <!-- Per-column filters, typed from the report metadata: date -> range, number -> range,
           boolean -> select, text -> contains. Applied server-side (the query is wrapped with the
           conditions), so pagination, count and export all reflect them. -->
      <div x-show="showFilters && !preview" x-h-card class="mx-4">
        <div x-h-card-content class="vbox gap-3">
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-4 gap-y-2">
            <template x-for="col in reportColumns" :key="col.key">
              <div class="vbox gap-0">
                <label class="text-xs text-muted-foreground" x-text="col.key"></label>
                <template x-if="col.kind === 'date'">
                  <div class="hbox gap-1 items-center">
                    <input x-h-input type="date" x-model="filters[col.key].from" @keydown.enter="applyFilters()" />
                    <span x-h-text.muted>&ndash;</span>
                    <input x-h-input type="date" x-model="filters[col.key].to" @keydown.enter="applyFilters()" />
                  </div>
                </template>
                <template x-if="col.kind === 'number'">
                  <div class="hbox gap-1 items-center">
                    <div x-h-input-number><input type="number" step="any" placeholder="min" x-model.number="filters[col.key].min" @keydown.enter="applyFilters()" /></div>
                    <span x-h-text.muted>&ndash;</span>
                    <div x-h-input-number><input type="number" step="any" placeholder="max" x-model.number="filters[col.key].max" @keydown.enter="applyFilters()" /></div>
                  </div>
                </template>
                <template x-if="col.kind === 'boolean'">
                  <div x-h-select>
                    <input x-h-select-input x-model="filters[col.key].equals" placeholder="any" />
                    <div x-h-select-content>
                      <div x-h-select-option="'any'" data-value=""></div>
                      <div x-h-select-option="'yes'" data-value="true"></div>
                      <div x-h-select-option="'no'" data-value="false"></div>
                    </div>
                  </div>
                </template>
                <template x-if="col.kind === 'text'">
                  <input x-h-input type="text" placeholder="contains..." x-model="filters[col.key].contains" @keydown.enter="applyFilters()" />
                </template>
              </div>
            </template>
          </div>
          <div class="hbox gap-2">
            <button x-h-button data-size="sm" @click="applyFilters()"><i role="img" data-lucide="check"></i><span>Apply</span></button>
            <button x-h-button data-variant="outline" data-size="sm" @click="clearFilters()"><i role="img" data-lucide="x"></i><span>Clear</span></button>
          </div>
        </div>
      </div>

      <div x-show="state === 'loading'" class="p-4"><div x-h-spinner></div></div>
      <div x-show="state === 'error'" x-h-alert data-variant="negative" role="alert" class="m-4"><div x-h-alert-description x-text="error"></div></div>
      <div x-show="state === 'empty'" x-h-info-page class="p-4">
        <div x-h-info-page-header>
          <div x-h-info-page-media.icon><svg x-h-icon data-icon="circle-info" role="img" aria-label="info"></svg></div>
          <div x-h-info-page-title>No data</div>
          <div x-h-info-page-description>The ${name} report returned no rows.</div>
        </div>
      </div>

      <div x-show="state === 'default'" class="vbox gap-2 p-4 flex-1 overflow-auto">
#if($chart)
        <!-- Chart surface: the report's aggregated rows rendered as a ${chart} chart (Chart.js). -->
        <div x-show="view === 'chart'" class="flex-1" style="position: relative; min-height: 60vh;">
          <canvas x-ref="chartCanvas"></canvas>
        </div>
        <div x-show="view === 'table'" class="vbox gap-2">
#end
        <div x-h-table-container.scroll data-border="true">
          <table x-h-table data-borders="both">
            <thead x-h-table-header>
              <tr x-h-table-row>
                <template x-for="(col, i) in columns" :key="i"><th x-h-table-head scope="col" :class="alignClass(col)" x-text="col"></th></template>
              </tr>
            </thead>
            <tbody x-h-table-body>
              <template x-for="(row, ri) in rows" :key="ri">
                <tr x-h-table-row data-hoverable="true">
                  <template x-for="(col, ci) in columns" :key="ci"><td x-h-table-cell :class="alignClass(col)" x-text="cellText(col, row)"></td></template>
                </tr>
              </template>
            </tbody>
          </table>
        </div>

        <div x-show="!preview" class="hbox items-center gap-2">
          <button x-h-button data-variant="outline" data-size="sm" :disabled="page <= 1" @click="prev()"><i role="img" data-lucide="chevron-left"></i><span>Prev</span></button>
          <span x-h-text.muted x-text="'Page ' + page + ' / ' + totalPages"></span>
          <button x-h-button data-variant="outline" data-size="sm" :disabled="page >= totalPages" @click="next()"><span>Next</span><i role="img" data-lucide="chevron-right"></i></button>
        </div>
#if($chart)
        </div>
#end
      </div>
    </div>

#if($chart)
    <!-- Chart.js (webjar): drives the ${chart} chart rendering for this report page. -->
    <script src="/webjars/chart.js/dist/chart.umd.js"></script>
#end
    <!-- Value formatter (window.HarmoniaFormat): report.js formats numeric cells through it; must load before Alpine inits. -->
    <script src="/services/web/application-core/shell/js/services/format.js"></script>
    <script src="./report.js"></script>
    <script defer src="/webjars/alpinejs/dist/cdn.min.js"></script>
    <script src="/webjars/codbex__harmonia/dist/harmonia.min.js"></script>
    <script src="/webjars/lucide/dist/umd/lucide.min.js"></script>
    <script>
      document.addEventListener('alpine:initialized', () => { if (window.lucide) window.lucide.createIcons(); }, { once: true });
      // Cross-frame / cross-tab colour-scheme sync is handled by Harmonia itself (harmonia.min.js
      // registers its own `storage` listener and re-applies codbex.harmonia.colorMode without re-persisting).
    </script>
  </body>
</html>
