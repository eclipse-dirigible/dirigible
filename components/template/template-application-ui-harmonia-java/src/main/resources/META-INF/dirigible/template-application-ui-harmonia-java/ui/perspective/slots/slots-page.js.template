/*
 * Slots page for ${name} — an appointment/booking picker built on Harmonia x-h-slot-picker.
 * Free slots (from ${slotOpen} to ${slotClose}, every ${slotStep} min) are bookable; picking one opens
 * the shared ${name}FormPage create form prefilled with the chosen datetime (?${slotStartProperty}=).
 * Existing bookings are loaded so their slots can be shown taken.
 */
document.addEventListener('alpine:init', () => {
  Alpine.data('${name}SlotsPage', () => ({
    ...basePage(),
    state: 'loading',
    error: null,
    items: [],
    // Config object for x-h-slot-picker (shorthand start/end/step + disabled weekdays).
    slotCfg: {
      start: '${slotOpen}',
      end: '${slotClose}',
      step: ${slotStep},
#if($slotDisabledDays)
      disabledDays: [${slotDisabledDays}],
#end
      slots: []
    },

    apiPath: '/${javaPerspectiveName}/${name}Controller',
    caView: '${name}',

    async init() { await this.load(); },

    async load() {
      this.state = 'loading';
      this.error = null;
      try {
        this.items = await App.services.api.getAll(this.apiPath);
        // Mark already-booked datetimes as taken (best-effort: keys the picker off exact start times).
        this.slotCfg = { ...this.slotCfg, slots: this.bookedSlots() };
        this.state = 'default';
      } catch (e) {
        this.error = App.services.apiErrors.messageFor(e, 'Could not load ${menuLabel}.');
        this.state = 'error';
      }
      this.refreshIcons();
    },

    // Build explicit unavailable slots for the datetimes already booked, so they render taken. A day
    // with any booked slot is expanded to its full generated grid (open..close by step) with the booked
    // ones flagged unavailable; days with no bookings fall back to the shorthand schedule (fillEmptyDays).
    bookedSlots() {
      const booked = {};
      for (const row of (this.items || [])) {
        const iso = this.toISO(row.${slotStartProperty});
        if (!iso || iso.indexOf('T') < 0) continue;
        const [d, t] = iso.split('T');
        (booked[d] = booked[d] || new Set()).add(t.slice(0, 5));
      }
      const out = [];
      const step = ${slotStep};
      const [oh, om] = '${slotOpen}'.split(':').map(Number);
      const [ch, cm] = '${slotClose}'.split(':').map(Number);
      const open = oh * 60 + om, close = ch * 60 + cm;
      const p = n => String(n).padStart(2, '0');
      for (const d of Object.keys(booked)) {
        for (let m = open; m < close; m += step) {
          const s = p(Math.floor(m / 60)) + ':' + p(m % 60);
          const e = p(Math.floor((m + step) / 60)) + ':' + p((m + step) % 60);
          out.push({ date: d, start: s, end: e, available: !booked[d].has(s) });
        }
      }
      return out;
    },

    // Jackson java.time -> ISO string (see the calendar page; slots need a datetime).
    toISO(v) {
      if (v === undefined || v === null || v === '') return '';
      if (Array.isArray(v)) {
        const p = n => String(n).padStart(2, '0');
        const date = v[0] + '-' + p(v[1]) + '-' + p(v[2]);
        return v.length <= 3 ? date : date + 'T' + p(v[3] || 0) + ':' + p(v[4] || 0) + ':' + p(v[5] || 0);
      }
      if (typeof v === 'number') {
        // Jackson serializes Instant/Timestamp as epoch SECONDS (with nanos); JS Date wants millis.
        const ms = v < 1e12 ? v * 1000 : v;
        try { return new Date(ms).toISOString(); } catch (e) { return ''; }
      }
      return String(v);
    },

    // Slot click -> create the booking prefilled with the chosen datetime (YYYY-MM-DDTHH:MM).
    onSlotClick(e) {
      const slot = e && e.detail ? e.detail.slot : null;
      if (!slot || slot.available === false) return;
      const val = slot.date + 'T' + slot.start;
      window.PineconeRouter.navigate('/${name}/create?${slotStartProperty}=' + encodeURIComponent(val));
    },
    newEntity() { window.PineconeRouter.navigate('/${name}/create'); }
  }));
}, { once: true });
