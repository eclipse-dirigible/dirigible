    "playwright",
    "integration-test",
    "intent",
    "low-code"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/eclipse-dirigible/dirigible.git",
    "directory": "npm/test"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.45"
  }
}
